curl -fsSL https://raw.githubusercontent.com/<org>/mycelium/main/mycelium.sh \
  -o ~/.local/bin/mycelium.sh && chmod +x ~/.local/bin/mycelium.sh

~/.local/bin works on Linux (XDG), macOS, and Git Bash on Windows.
Org is likely openprose (see ../platform remote).
