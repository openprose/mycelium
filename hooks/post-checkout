#!/usr/bin/env bash
# Example post-checkout hook — gentle awareness that mycelium exists.
# Copy to .git/hooks/post-checkout and chmod +x.
#
# Runs on branch switch. One-liner if mycelium notes exist.

# Only on branch switches, not file checkouts
[[ "$3" == "1" ]] || exit 0

# Are there mycelium notes?
count=$(git notes --ref=mycelium list 2>/dev/null | wc -l)
[[ "$count" -gt 0 ]] || exit 0

echo "ℹ  Coding agents use $count mycelium notes in this repo (invisible to normal git)."
