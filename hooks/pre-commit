#!/usr/bin/env bash
# Example pre-commit hook — tests + secret scan.
# Copy to .git/hooks/pre-commit and chmod +x.
set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)

STAGED=$(git diff --cached --name-only)

# Run core tests if runtime, workflow scripts, hooks/, or anything under test/ is staged
if echo "$STAGED" | grep -qE '^(install\.sh|mycelium\.sh|scripts/|hooks/|test/)' 2>/dev/null; then
  echo "running core tests..."
  # Hooks inherit git-local env vars (GIT_DIR, GIT_WORK_TREE, etc.).
  # Clear them before running the inner temp repos created by the test suite.
  while read -r var; do unset "$var"; done < <(git rev-parse --local-env-vars)

  if [[ -x "$REPO_ROOT/test/test.sh" ]]; then
    "$REPO_ROOT/test/test.sh" >/dev/null || { echo "test/test.sh failed"; exit 1; }
  fi
  for suite in "$REPO_ROOT"/test/test-multi-repo-*.sh; do
    [[ -x "$suite" ]] || continue
    "$suite" >/dev/null || { echo "$(basename "$suite") failed"; exit 1; }
  done

  echo "core tests passed"
fi

# Run plugin spec tests if anything in integrations/, PLUGIN-SPEC.md, or
# test/test-plugin-spec.sh is staged. These verify the Claude Code + Pi
# adapters against the unified plugin contract.
if echo "$STAGED" | grep -qE '^(integrations/|PLUGIN-SPEC\.md$|test/test-plugin-spec\.sh$)' 2>/dev/null; then
  if [[ -x "$REPO_ROOT/test/test-plugin-spec.sh" ]]; then
    echo "running plugin spec tests..."
    while read -r var; do unset "$var"; done < <(git rev-parse --local-env-vars)
    "$REPO_ROOT/test/test-plugin-spec.sh" >/dev/null || {
      echo "test/test-plugin-spec.sh failed"
      exit 1
    }
    echo "plugin spec tests passed"
  fi
fi

# Run Pi extension bun tests + typecheck if integrations/pi/ is staged.
# Skip gracefully if bun is not installed — we don't want to force a bun
# dependency on contributors who only touch the Claude Code side.
if echo "$STAGED" | grep -q '^integrations/pi/' 2>/dev/null; then
  if command -v bun &>/dev/null; then
    echo "running pi extension tests..."
    (
      cd "$REPO_ROOT/integrations/pi" || exit 1
      # bun install is cheap if node_modules is already populated
      bun install --silent >/dev/null 2>&1 || true
      bun run typecheck >/dev/null 2>&1 || { echo "integrations/pi: typecheck failed"; exit 1; }
      bun test >/dev/null 2>&1 || { echo "integrations/pi: bun test failed"; exit 1; }
    ) || exit 1
    echo "pi extension tests passed"
  fi
fi

# Version: verify git describe works (catches detached HEAD with no tags)
if echo "$STAGED" | grep -q '^mycelium\.sh$' 2>/dev/null; then
  VERSION=$(git describe --tags --always 2>/dev/null || echo "")
  if [[ -z "$VERSION" ]]; then
    echo "Warning: git describe failed — no tags? Run: git tag -a v0.1.0 -m 'release'" >&2
  fi
fi

# Secret scan
if command -v gitleaks &>/dev/null; then
  gitleaks git --staged --no-banner --redact -l warn
fi

# UBS scan (if installed)
if command -v ubs &>/dev/null; then
  ubs --ci --fail-on-warning "$REPO_ROOT" >/dev/null 2>&1 || {
    echo "ubs found warnings — run 'ubs .' to see details"
    exit 1
  }
fi
